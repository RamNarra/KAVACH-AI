rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read/write APKs only under their own UID directory
    match /apks/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Default fallback: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
