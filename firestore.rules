rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read and write analysis results
    match /apkanalysisresults/{document} {
      allow read, write: if request.auth != null;
    }
    
    // Default rule: require authentication for any other collection
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
