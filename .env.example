# ============================================================
# KAVACH AI - Environment Configuration Example
# ============================================================
# Copy this file to '.env' at the root of the project and
# fill in ALL values marked CHANGE_ME before starting the stack.
#
# ⚠️  NEVER commit your real '.env' file to git.
#     The .gitignore already excludes *.env — keep it that way.
# ============================================================

# --- Google Gemini / GenAI Cloud Configuration ---
# Your Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY="CHANGE_ME_your_google_ai_studio_api_key"

# --- JWT Authentication ---
# Must be a cryptographically random string, minimum 64 characters.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
KAVACH_JWT_SECRET="CHANGE_ME_minimum_64_char_random_hex_string"

# --- AES-256 Encryption Key for Secrets at Rest ---
# Used to encrypt user Gemini API keys stored in the database.
# MUST be different from KAVACH_JWT_SECRET.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY="CHANGE_ME_different_minimum_64_char_random_hex_string"

# --- Database Encryption Key (separate from SECRET_KEY) ---
# MUST be different from both KAVACH_JWT_SECRET and SECRET_KEY.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
KAVACH_DB_ENCRYPTION_KEY="CHANGE_ME_yet_another_unique_64_char_random_hex_string"

# --- Database / Local PostgreSQL Configuration ---
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_USER="kavach_user"
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD="CHANGE_ME_strong_random_db_password"
POSTGRES_DB="kavach_db"

# --- VirusTotal Static Integration (Optional) ---
# Add your VirusTotal API key below to enable the VirusTotal static scan tab
VIRUSTOTAL_API_KEY=""

# --- MobSF Programmatic Sandbox (Optional) ---
# Generate a strong random key for MobSF REST API authentication.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
MOBSF_API_KEY="CHANGE_ME_strong_random_mobsf_api_key"
MOBSF_API_URL="http://localhost:8000"

# --- Orchestrator & Sandbox Optimization ---
KAVACH_DOCKER_SANDBOX=0
KAVACH_ALLOW_LEGACY_UID=0
KAVACH_DISABLE_JADX_CACHE=1
JADX_THREADS=8
