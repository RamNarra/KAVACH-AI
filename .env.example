# ============================================================
# KAVACH AI - Environment Configuration Example
# Copy this file to '.env' at the root of the project.
# ============================================================

# --- Google Gemini / GenAI Cloud Configuration ---
# Your Google AI Studio API key
GEMINI_API_KEY="AIzaSy..."

# --- Database / Supabase Backend ---
# Your Supabase instance URL and service role key (for user auth and storage)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="eyJhbGciOiJIUz..."
SUPABASE_JWT_SECRET="super_secret_kavach_jwt_security_token_1337"

# --- VirusTotal Static Integration (Optional) ---
# Add your VirusTotal API key below to enable the VirusTotal static scan tab
VIRUSTOTAL_API_KEY=""

# --- MobSF Programmatic Sandbox (Optional) ---
MOBSF_API_KEY="mobsf_kavach_secret_key_1337"
MOBSF_API_URL="http://localhost:8000"

# --- Orchestrator & Sandbox Optimization ---
KAVACH_DOCKER_SANDBOX=0
KAVACH_ALLOW_LEGACY_UID=0
KAVACH_DISABLE_JADX_CACHE=1
JADX_THREADS=8
